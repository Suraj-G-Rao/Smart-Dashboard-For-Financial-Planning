# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/financeai?schema=public"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars_random

# Google OAuth (for NextAuth Google provider)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Email Provider (for NextAuth Email provider)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_email@gmail.com
EMAIL_SERVER_PASSWORD=your_email_app_password
EMAIL_FROM=noreply@financeai.com

# AI Services
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=your_openai_api_key

# Vault Encryption (CRITICAL - Generate a strong 64-char hex secret)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_SECRET=your_64_char_hex_secret_for_encryption

# File Upload Configuration
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads
# For S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=financeai-vault

# Auto-lock timeout (minutes)
VAULT_AUTO_LOCK_MINUTES=10

# Analytics & Features
ENABLE_AI_COACH=true
ENABLE_SALARY_PREDICTOR=true
ENABLE_GOAL_FORECASTING=true

# Optional: Email for reports/notifications
SMTP_HOST=localhost
SMTP_PORT=1025
