// Prisma Schema for FinanceAI Application
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USER MODELS
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  currency      String    @default("INR")
  riskProfile   String?   // conservative | moderate | aggressive
  vaultSalt     String?   // For key derivation
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  insights          Insight[]
  salaryHistory     SalaryHistory[]
  goals             Goal[]
  insurancePolicies InsurancePolicy[]
  subscriptions     Subscription[]
  bills             Bill[]
  vaultItems        VaultItem[]
  transactions      Transaction[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// AI & INSIGHTS MODELS
// ============================================================================

model Insight {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // coach_tip | anomaly | goal_forecast | salary_advice
  content   Json     // Flexible JSON structure for different insight types
  metadata  Json?    // Additional metadata (period, category, etc.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([userId, createdAt])
}

// ============================================================================
// SALARY PREDICTOR MODELS
// ============================================================================

model SalaryHistory {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  baseCTC   Decimal  @db.Decimal(15, 2)
  bonus     Decimal  @default(0) @db.Decimal(15, 2)
  title     String?
  skills    String[] // Array of skill tags
  city      String?
  company   String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ============================================================================
// GOALS & FORECASTING MODELS
// ============================================================================

model Goal {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String?
  targetAmount Decimal   @db.Decimal(15, 2)
  targetDate   DateTime?
  savedAmount  Decimal   @default(0) @db.Decimal(15, 2)
  priority     Int       @default(2) // 1=High, 2=Medium, 3=Low
  status       String    @default("Active") // Active | Completed | Paused
  category     String?   // Vacation, Education, Emergency, Home, etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ============================================================================
// INSURANCE MODELS
// ============================================================================

model InsurancePolicy {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  policyType     String   // Term, Health, Motor, Life, Travel
  policyNumber   String
  coverageAmount Decimal  @db.Decimal(15, 2)
  premium        Decimal  @db.Decimal(15, 2)
  premiumCycle   String   // monthly | quarterly | yearly
  startDate      DateTime
  endDate        DateTime
  nextPremiumOn  DateTime
  status         String   @default("Active") // Active | Expired | Cancelled | Planned
  attachments    String[] // File paths in Vault
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, nextPremiumOn])
}

// ============================================================================
// LIFE MODULES MODELS
// ============================================================================

model Subscription {
  id         String   @id @default(cuid())
  userId     String
  service    String
  amount     Decimal  @db.Decimal(15, 2)
  cycle      String   // monthly | yearly
  nextRenew  DateTime
  category   String   @default("Subscription") // Streaming, Software, Music, etc.
  isActive   Boolean  @default(true)
  lastUsed   DateTime? // For usage tracking
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, nextRenew])
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(15, 2)
  dueDate   DateTime
  category  String   // Utilities, Rent, Credit Card, etc.
  isPaid    Boolean  @default(false)
  paidOn    DateTime?
  recurring Boolean  @default(false) // If true, auto-create next month
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, isPaid])
}

// ============================================================================
// VAULT & SECURITY MODELS
// ============================================================================

model VaultItem {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String   // document | password | note | card
  path      String?  // File path or S3 key for documents
  secret    String?  @db.Text // Encrypted value for passwords/notes
  iv        String?  // Initialization vector for encryption
  tag       String?  // Authentication tag for encryption
  metadata  Json?    // Additional metadata (size, mimetype, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

// ============================================================================
// TRANSACTIONS & ANALYTICS MODELS
// ============================================================================

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(15, 2)
  type        String   // income | expense
  category    String
  description String?
  date        DateTime
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type, category])
}

// ============================================================================
// BUDGET & LIMITS MODELS
// ============================================================================

model BudgetLimit {
  id        String   @id @default(cuid())
  userId    String
  category  String
  limit     Decimal  @db.Decimal(15, 2)
  month     DateTime // First day of the month
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, month])
  @@index([userId, month])
}
